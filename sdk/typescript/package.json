{
  "name": "qrd-sdk",
  "version": "0.1.0",
  "description": "TypeScript bindings for QRD columnar format",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "webpack",
    "build:wasm": "wasm-pack build ../../core/qrd-wasm --target web --out-dir ../../typescript/pkg",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "npm run build:wasm && npm run build"
  },
  "keywords": ["columnar", "data-format", "binary", "typescript", "wasm"],
  "author": "QRD Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "ts-loader": "^9.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "wasm-pack": "^0.12.0"
  },
  "dependencies": {
    "qrd-wasm": "file:./pkg"
  }
}